-- ----------------------------------------------------------------------------

---Is this slug flagged in the given slug-set preference?
---@param pref string preference key (a schema.set of slugs)
---@param slug string
---@return boolean
local function slug_flag(pref, slug)
	local set = editor.prefs.get(pref) or EMPTY_LIST
	return set[slug] == true
end

---Flag/unflag a slug in the given slug-set preference (project scope).
---@param pref string preference key (a schema.set of slugs)
---@param slug string
---@param flagged boolean
local function set_slug_flag(pref, slug, flagged)
	local set = editor.prefs.get(pref) or EMPTY_LIST
	local copy = {}
	for k, v in pairs(set) do
		copy[k] = v
	end
	copy[slug] = flagged or nil   -- sets store `true` values; absent means false
	editor.prefs.set(pref, copy)
end

-- ----------------------------------------------------------------------------
-- Destination folder helpers
-- ----------------------------------------------------------------------------

---State of "/<folder>" in the project (pcall guards free-typed input the resource system rejects).
---@param folder string project-relative folder path, no leading slash
---@return boolean exists
---@return boolean is_file it exists but is a file, not a directory
local function folder_state(folder)
	if folder == "" then
		return false, false
	end
	local ok, attrs = pcall(editor.resource_attributes, "/" .. folder)
	if not ok or type(attrs) ~= "table" then
		return false, false
	end
	return attrs.exists == true, attrs.is_file == true
end

---Validation message for a destination folder path, or nil when usable (is_file comes from folder_state).
---@param folder string project-relative folder path, no leading slash
---@param is_file boolean whether /<folder> currently exists as a file
---@return string|nil
local function folder_issue_message(folder, is_file)
	if folder == "" then
		return "Folder name is required"
	end
	if folder:match("^/") or folder:match("/$") or folder:find("//", 1, true) then
		return 'Use a project-relative path like "my-pack" or "packs/my-pack"'
	end
	for segment in folder:gmatch("[^/]+") do
		if not segment:match("^[%w_%-][%w_%-%.]*$") then
			return "Only letters, digits, '_', '-' and '.' are supported (no leading dot)"
		end
	end
	local first = folder:match("^[^/]+")
	if first == "builtins" or first == "build" then
		return '"/' .. first .. '" is reserved by Defold'
	end
	if is_file then
		return '"/' .. folder .. '" is an existing file, not a folder'
	end
	return nil
end

