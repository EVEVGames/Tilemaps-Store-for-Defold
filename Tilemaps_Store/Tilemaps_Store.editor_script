	return {
		[PREF_TOKEN] = editor.prefs.schema.password({
			scope = editor.prefs.SCOPE.GLOBAL,
		}),
		[PREF_OVERWRITE] = editor.prefs.schema.set({
			item = editor.prefs.schema.string(),
			scope = editor.prefs.SCOPE.PROJECT,
		}),
		[PREF_NO_ASSETS] = editor.prefs.schema.set({
			item = editor.prefs.schema.string(),
			scope = editor.prefs.SCOPE.PROJECT,
		}),
		[PREF_KEEP_COLLECTION] = editor.prefs.schema.set({
			item = editor.prefs.schema.string(),
			scope = editor.prefs.SCOPE.PROJECT,
		}),
		[PREF_FOLDERS] = editor.prefs.schema.object_of({
			key = editor.prefs.schema.string(),
			val = editor.prefs.schema.string(),
			scope = editor.prefs.SCOPE.PROJECT,
		}),
		[PREF_TITLES] = editor.prefs.schema.object_of({
