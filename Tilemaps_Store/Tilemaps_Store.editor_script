---Percent-encode a string for use in a URL query value or path segment.
---@param str any
---@return string
local function url_encode(str)
	return (tostring(str):gsub("[^%w%-_%.~]", function(c)
		return string.format("%%%02X", string.byte(c))
	end))
end

---Build a query string from a table, skipping nil/empty values.
---@param params table
---@return string
local function build_query(params)
	local parts = {}
	for key, value in pairs(params) do
		if value ~= nil and value ~= "" then
			parts[#parts + 1] = url_encode(key) .. "=" .. url_encode(value)
		end
	end
	return table.concat(parts, "&")
end

---Turn a possibly-relative thumbnail URL into an absolute one.
---@param url string
---@return string
local function absolute_url(url)
	if url:match("^https?://") then
		return url
	elseif url:sub(1, 1) == "/" then
		return BASE_URL .. url
	end
	return BASE_URL .. "/" .. url
end

---Return the first non-empty thumbnail URL from a project's thumbnails array.
---@param thumbnails any
---@return string|nil
local function first_thumb(thumbnails)
	if type(thumbnails) ~= "table" then
		return nil
	end
	for _, url in ipairs(thumbnails) do
		if type(url) == "string" and url ~= "" then
			return absolute_url(url)
		end
	end
	return nil
end

---Perform an authenticated GET against /api/v1/<method>, decoding JSON.
---@param method string API method name
---@param token string API key, sent as an Authorization: Bearer header
---@param params table|nil extra query parameters
---@return table|nil body decoded JSON body, or nil on error
---@return string|nil err "unauthorized" or a human-readable message on error
local function api_get(method, token, params)
	local url = API_URL .. method
	local query = build_query(params or {})
	if query ~= "" then
		url = url .. "?" .. query
	end

	local ok, response = pcall(http.request, url, {
		as = "json",
		headers = { Authorization = "Bearer " .. token },
	})
	if not ok then
		return nil, "network error: " .. tostring(response)
	end
	if response.status == 401 then
		return nil, "unauthorized"
	end
	if response.status ~= 200 then
		local msg = (type(response.body) == "table" and response.body.error)
			or ("HTTP " .. tostring(response.status))
		return nil, msg
	end
	return response.body, nil
end

---Map a download HTTP status to a friendly message.
---@param status integer
---@return string
local function download_status_message(status)
	if status == 0 then return "network error — no response from server" end
	if status == 401 then return "unauthorized — check your API token" end
	if status == 402 then return "payment required — this is a paid project you don't own" end
	if status == 403 then return "forbidden — no access to this project or build" end
	if status == 404 then return "not found — no Defold export for this release" end
	return "HTTP " .. tostring(status)
end

---Fetch the server's error text for a failed download (the streaming download discards the body).
---@param url string
---@param headers table request headers (the Bearer auth)
---@param status integer the error status already seen
---@return string
local function download_error_message(url, headers, status)
	local ok, resp = pcall(http.request, url, { as = "json", headers = headers })
	if ok and type(resp.body) == "table" and type(resp.body.error) == "string" then
		return resp.body.error .. " (HTTP " .. status .. ")"
	end
	return download_status_message(status)
end

---Stream `url` to absolute path `dest` with Bearer auth; returns HTTP status, or nil+err on network failure.
---http.request `path` writes bytes verbatim over IPv4; on an error status no file is written (path & as are exclusive).
---@param url string
---@param dest string absolute destination path
---@param token string API key, sent as an Authorization: Bearer header
---@return integer|nil status
---@return string|nil err
local function download_file(url, dest, token)
	local ok, resp = pcall(http.request, url, {
		path = dest,
		headers = { Authorization = "Bearer " .. token },
	})
	if not ok then
		return nil, "network error: " .. tostring(resp)
	end
	return resp.status
end

-- ----------------------------------------------------------------------------
-- Resource path adaptation
-- ----------------------------------------------------------------------------
-- Exports use root-absolute resource paths; under /<folder>/ they break, so we rewrite quoted refs
-- that match an extracted file to their new path. Unmatched refs (/builtins, URLs) and game.project.sample are left as-is.

---Normalize OS path separators to "/".
local function to_slash(s)
	return (s:gsub(PATH_SEP, "/"))
end

---basename (segment after the last separator).
local function basename(p)
	return to_slash(p):match("[^/]+$")
end

---lowercase file extension without the dot.
local function file_ext(name)
	return (name:match("%.([%w]+)$") or ""):lower()
end

---Resource path of `abs` relative to a base of normalized length `base_len`.
local function res_path(abs, base_len)
	local rel = to_slash(abs):sub(base_len + 1)
	if rel:sub(1, 1) ~= "/" then rel = "/" .. rel end
	return rel
end

---Recursively list files (not directories) under an absolute directory.
local function list_files_recursive(dir_abs)
	local out
	if IS_WINDOWS then
		out = editor.execute("cmd", "/c", "dir", "/b", "/s", "/a-d", dir_abs,
			{ out = "capture", err = "discard", reload_resources = false })
	else
		out = editor.execute("find", dir_abs, "-type", "f",
			{ out = "capture", err = "discard", reload_resources = false })
	end
	local files = {}
	if out then
		for line in tostring(out):gmatch("[^\r\n]+") do
			files[#files + 1] = line
		end
	end
	return files
end

---Rewrite absolute resource references inside the extracted project to their new /<folder>/... location.
---@param extract_dir string
---@param user_root string the Defold project root (absolute)
local function adapt_resource_paths(extract_dir, user_root)
	local files = list_files_recursive(extract_dir)
	if #files == 0 then return end

	-- The export's root is the dir holding game.project(.sample); resource paths are absolute from there.
	local proj_root = extract_dir
	for _, f in ipairs(files) do
		local name = basename(f)
		if name == "game.project.sample" or name == "game.project" then
			proj_root = f:sub(1, #f - #name - 1)  -- strip separator + name
			break
		end
	end

	local user_len = #to_slash(user_root)
	local proj_norm = to_slash(proj_root)
	local proj_len = #proj_norm

	-- old (export-root-relative) path -> new (project-root-relative) path.
	local map = {}
	for _, f in ipairs(files) do
		if to_slash(f):sub(1, proj_len) == proj_norm then
			map[res_path(f, proj_len)] = res_path(f, user_len)
		end
	end

	local function rewrite(content)
		return (content:gsub("([\"'])(/[^\"'%c]*)([\"'])", function(q1, p, q2)
			local mapped = map[p]
			if mapped then return q1 .. mapped .. q2 end
			return q1 .. p .. q2
		end))
	end

	for _, f in ipairs(files) do
		if to_slash(f):sub(1, proj_len) == proj_norm then
			local name = basename(f)
			if name ~= "game.project.sample" and not BINARY_EXT[file_ext(name)] then
				local fh = io.open(f, "rb")
				if fh then
					local content = fh:read("*a") or ""
					fh:close()
					if not content:find("\0", 1, true) then  -- skip binaries missed by the extension check
						local new_content = rewrite(content)
						if new_content ~= content then
							local w = io.open(f, "wb")
							if w then
								w:write(new_content)
								w:close()
							end
						end
					end
				end
			end
		end
	end
end

-- ----------------------------------------------------------------------------
-- Collection -> native .tilemap conversion (orthogonal maps only)
-- ----------------------------------------------------------------------------
-- Tilemaps.com always exports Defold projects as a .collection — one child .go per layer, one
-- sprite component per tile — because that's the only format that covers isometric projection
-- and per-tile animation. For a large, purely orthogonal map that flexibility costs runtime
-- performance: hundreds or thousands of game objects instead of a single Tile Map component.
-- When the user opts in, we detect orthogonal, single-tileset, sprite-grid collections from
-- their own file shape (no server round-trip) and replace them with a native .tilemap wrapped
-- by a plain .go (Defold's Tile Map component always needs a game object to live in — a
-- .collection can't reference one directly). The original .collection is removed rather than
-- kept as a compatibility shim: this is an explicit, reversible opt-in, so anyone who needs the
-- multi-layer .collection back can simply download again with the option unchecked. Isometric
-- or otherwise non-grid collections are left untouched.

local GRID_EPSILON = 0.01  -- world units of slack when checking tile-center alignment

---Read a whole file as text, or nil if it can't be opened.
---@param path string absolute path
---@return string|nil
local function read_file(path)
	local fh = io.open(path, "rb")
	if not fh then return nil end
	local content = fh:read("*a")
	fh:close()
	return content
end

---Write `content` to `path` (created/truncated). Returns true on success.
---@param path string absolute path
---@param content string
---@return boolean
local function write_file(path, content)
	local fh = io.open(path, "wb")
	if not fh then return false end
	local ok = fh:write(content)
	fh:close()
	return ok ~= nil
end

---Format a number for Defold's protobuf text format: always carries a decimal point.
---@param n number
---@return string
local function fmt_float(n)
	local s = string.format("%.6g", n)
	if not s:find("[%.eE]") then
		s = s .. ".0"
	end
	return s
end

---Root-relative resource path (e.g. "/folder/x.go") -> absolute filesystem path. The inverse of `res_path`.
---@param res string
---@param root_abs string project root (absolute)
---@return string
local function resolve_resource(res, root_abs)
	return root_abs .. PATH_SEP .. (res:gsub("^/", ""):gsub("/", PATH_SEP))
end

---Is `value` within `eps` of an integer?
---@param value number
---@param eps number
---@return boolean
local function near_integer(value, eps)
	return math.abs(value - math.floor(value + 0.5)) < eps
end

---Parse `id`/`prototype` out of every top-level `instances { ... }` block, in file order. nil when
---the collection has no instances, or uses `embedded_instances` (inlined children — too irregular
---to reason about safely).
---@param text string .collection content
---@return table[]|nil instances array of { id, prototype }
local function parse_collection_instances(text)
	if text:find("embedded_instances", 1, true) then
		return nil
	end
	local out = {}
	for block in text:gmatch("instances%s*(%b{})") do
		local id = block:match('id:%s*"([^"]*)"')
		local prototype = block:match('prototype:%s*"([^"]*)"')
		if not id or not prototype then
			return nil
		end
		out[#out + 1] = { id = id, prototype = prototype }
	end
	if #out == 0 then
		return nil
	end
	return out
end

---Parse every `components { ... }` block of a .go file as a sprite-tile placement. nil when any
---component isn't a plain sprite reference with a position, or the file uses `embedded_components`
---— that .go isn't a pure per-tile sprite layer. An empty (but valid) result is a layer with no tiles.
---@param text string .go content
---@return table[]|nil cells array of { sprite = path, x, y, z }
local function parse_go_sprite_cells(text)
	if text:find("embedded_components", 1, true) then
		return nil
	end
	local out = {}
	for block in text:gmatch("components%s*(%b{})") do
		local sprite = block:match('component:%s*"([^"]*%.sprite)"')
		local pos = block:match("position%s*(%b{})")
		if not sprite or not pos then
			return nil
		end
		local x = tonumber(pos:match("x:%s*([%-%d%.]+)"))
		local y = tonumber(pos:match("y:%s*([%-%d%.]+)"))
		local z = tonumber(pos:match("z:%s*([%-%d%.]+)")) or 0
		if not x or not y then
			return nil
		end
		out[#out + 1] = { sprite = sprite, x = x, y = y, z = z }
	end
	return out
end

---@param text string .sprite content
---@return string|nil tile_set resource path
---@return string|nil default_animation
local function parse_sprite(text)
	return text:match('tile_set:%s*"([^"]*)"'), text:match('default_animation:%s*"([^"]*)"')
end

---@param text string .tilesource content
---@return integer|nil tile_width
---@return integer|nil tile_height
---@return table|nil starts animation id (string) -> start_tile (integer)
local function parse_tilesource(text)
	local tw = tonumber(text:match("tile_width:%s*(%d+)"))
	local th = tonumber(text:match("tile_height:%s*(%d+)"))
	if not tw or not th then
		return nil
	end
	local starts = {}
	for block in text:gmatch("animations%s*(%b{})") do
		local id = block:match('id:%s*"([^"]*)"')
		local start_tile = tonumber(block:match("start_tile:%s*(%d+)"))
		if not id or not start_tile then
			return nil
		end
		starts[id] = start_tile
	end
	return tw, th, starts
end

---Try to convert one exported map collection into a native, orthogonal .tilemap. Best-effort and
---read-only until every check passes — anything that doesn't match the expected shape (multiple
---tilesets, isometric placement, embedded content, …) leaves the collection untouched.
---@param collection_abs string absolute path to the .collection file
---@param root_abs string project root (absolute)
---@return "converted"|"isometric"|nil status
---@return string[]|nil sprites resource paths freed by the conversion (status == "converted" only)
local function try_convert_collection(collection_abs, root_abs)
	local coll_text = read_file(collection_abs)
	if not coll_text then return nil end

	local instances = parse_collection_instances(coll_text)
	if not instances then return nil end

	-- Resolve + parse every referenced .go as one layer, in instance order.
	local layers, go_abs_paths = {}, {}
	for _, inst in ipairs(instances) do
		if file_ext(inst.prototype) ~= "go" then
			return nil
		end
		local go_abs = resolve_resource(inst.prototype, root_abs)
		local go_text = read_file(go_abs)
		if not go_text then return nil end
		local cells = parse_go_sprite_cells(go_text)
		if not cells then return nil end
		go_abs_paths[#go_abs_paths + 1] = go_abs
		layers[#layers + 1] = { id = inst.id, cells = cells, z = cells[1] and cells[1].z or 0 }
	end

	-- Resolve each cell's sprite -> (shared tileset, animation id); bail on more than one tileset.
	local sprite_cache, tile_set_path = {}, nil
	for _, layer in ipairs(layers) do
		for _, cell in ipairs(layer.cells) do
			local resolved = sprite_cache[cell.sprite]
			if not resolved then
				local sprite_text = read_file(resolve_resource(cell.sprite, root_abs))
				if not sprite_text then return nil end
				local ts, anim = parse_sprite(sprite_text)
				if not ts or not anim then return nil end
				resolved = { tile_set = ts, anim = anim }
				sprite_cache[cell.sprite] = resolved
			end
			if not tile_set_path then
				tile_set_path = resolved.tile_set
			elseif tile_set_path ~= resolved.tile_set then
				return nil
			end
			cell.anim = resolved.anim
		end
	end
	if not tile_set_path then return nil end

	local tileset_text = read_file(resolve_resource(tile_set_path, root_abs))
	if not tileset_text then return nil end
	local tile_w, tile_h, starts = parse_tilesource(tileset_text)
	if not tile_w or not tile_h then return nil end

	-- Grid check + tile-id resolution in one pass: any cell off the orthogonal lattice flips the
	-- verdict to isometric (tilemaps.com's isometric export offsets tile centers by half a cell
	-- per row/column instead of landing on this rectangular grid).
	local half_w, half_h = tile_w / 2, tile_h / 2
	for _, layer in ipairs(layers) do
		for _, cell in ipairs(layer.cells) do
			local col_f = (cell.x - half_w) / tile_w
			local row_f = (cell.y - half_h) / tile_h
			if not (near_integer(col_f, GRID_EPSILON) and near_integer(row_f, GRID_EPSILON)) then
				return "isometric"
			end
			-- Tilesource `start_tile` is 1-based; a .tilemap cell's `tile` is 0-based (0 = first tile),
			-- so drop by one. The sprite that renders tilesource tile N is named tile_(N-1).sprite, so
			-- the result equals that suffix — a handy cross-check.
			local start_tile = starts[cell.anim]
			if not start_tile then return nil end
			cell.col, cell.row, cell.tile = math.floor(col_f + 0.5), math.floor(row_f + 0.5), start_tile - 1
		end
	end

	-- Build the native .tilemap text.
	local parts = { 'tile_set: "' .. tile_set_path .. '"\n' }
	for _, layer in ipairs(layers) do
		parts[#parts + 1] = 'layers {\n  id: "' .. layer.id .. '"\n  z: ' .. fmt_float(layer.z) .. '\n'
		for _, cell in ipairs(layer.cells) do
			parts[#parts + 1] = string.format(
				"  cell {\n    x: %d\n    y: %d\n    tile: %d\n  }\n", cell.col, cell.row, cell.tile)
		end
		parts[#parts + 1] = "}\n"
	end
	parts[#parts + 1] = 'material: "/builtins/materials/tile_map.material"\n'

	-- Sibling filenames next to the original .collection, which is removed below — its base name
	-- is free to reuse, so the replacement pair reads as "<name>.go" + "<name>.tilemap".
	local coll_name_file = basename(collection_abs)
	local dir = collection_abs:sub(1, #collection_abs - #coll_name_file - 1)
	local base = coll_name_file:gsub("%.collection$", "")
	local tilemap_abs = dir .. PATH_SEP .. base .. ".tilemap"
	local go_abs = dir .. PATH_SEP .. base .. ".go"

	if not write_file(tilemap_abs, table.concat(parts)) then return nil end

	local root_len = #to_slash(root_abs)
	local tilemap_res = res_path(tilemap_abs, root_len)
	if not write_file(go_abs, 'components {\n  id: "tilemap"\n  component: "' .. tilemap_res .. '"\n}\n') then
		return nil
	end

	-- Both new files are down; the .collection's job is done — drop it along with the per-layer
	-- .go files it used to wrap (exclusively owned by this collection, so always safe to remove).
	os.remove(collection_abs)
	for _, path in ipairs(go_abs_paths) do
		os.remove(path)
	end

	local sprite_candidates = {}
	for sprite_path in pairs(sprite_cache) do
		sprite_candidates[#sprite_candidates + 1] = sprite_path
	end
	return "converted", sprite_candidates
end

---Delete any of `sprite_paths` no longer referenced by any .go/.collection still present under
---`target_dir` — the only file types that can hold such a reference. Called once after every
---collection in a download has been converted, so a sprite shared across two map collections
---(unusual, but possible) survives until both have had their say.
---@param sprite_paths string[] root-relative resource paths
---@param root_abs string project root (absolute)
---@param target_dir string absolute path of the just-downloaded folder
local function delete_unused_sprites(sprite_paths, root_abs, target_dir)
	if #sprite_paths == 0 then return end

	local haystack = {}
	for _, f in ipairs(list_files_recursive(target_dir)) do
		local ext = file_ext(basename(f))
		if ext == "go" or ext == "collection" then
			haystack[#haystack + 1] = read_file(f) or ""
		end
	end
	local blob = table.concat(haystack, "\n")

	local seen = {}
	for _, res in ipairs(sprite_paths) do
		if not seen[res] then
			seen[res] = true
			if not blob:find(res, 1, true) then
				os.remove(resolve_resource(res, root_abs))
			end
		end
	end
end

---Convert every orthogonal, single-tileset, sprite-grid .collection under `target_dir` into a
---native .tilemap. Best-effort per file: a parse/shape failure just skips that file.
---@param target_dir string absolute path of the just-extracted download folder
---@param root_abs string project root (absolute)
---@return integer converted
---@return integer isometric kept as .collection because they aren't an orthogonal grid
local function convert_orthogonal_collections(target_dir, root_abs)
	local converted, isometric, freed = 0, 0, {}
	for _, f in ipairs(list_files_recursive(target_dir)) do
		if file_ext(basename(f)) == "collection" then
			local ok, status, sprites = pcall(try_convert_collection, f, root_abs)
			if ok and status == "converted" then
				converted = converted + 1
				for _, s in ipairs(sprites) do
					freed[#freed + 1] = s
				end
				print("[Tilemaps Store] Converted '" .. basename(f) .. "' to a native tile map.")
			elseif ok and status == "isometric" then
				isometric = isometric + 1
				print("[Tilemaps Store] Kept '" .. basename(f) .. "' as a collection (isometric map).")
			elseif not ok then
				print("[Tilemaps Store] Tile map conversion failed for '" .. basename(f) .. "': " .. tostring(status))
			end
		end
	end
	delete_unused_sprites(freed, root_abs, target_dir)
	return converted, isometric
end

---Download a project ZIP and extract its whole contents into /<folder>/ (created if missing), then adapt paths.
---@param url string
---@param folder string destination folder name (project.folder)
---@param opts table { token = string, overwrite = boolean, include_assets = boolean, convert_tilemap = boolean }
---@return boolean success
---@return string|nil err
---@return string|nil convert_note summary of any .collection -> .tilemap conversions performed
local function download_and_extract(url, folder, opts)
	-- Resolve absolute paths via the editor (subprocess CWD is not the project root).
	local internal = editor.external_file_attributes(".internal")
	local root = editor.external_file_attributes(".")
	if not (internal and internal.path and root and root.path) then
		return false, "cannot resolve project paths"
	end
	local sep = package.config:sub(1, 1)
	local tmp = internal.path .. sep .. TMP_ZIP_NAME
	local target = root.path .. sep .. folder

	local status, err = download_file(url, tmp, opts.token)
	if not status then
		return false, err
	end
	if status ~= 200 then
		return false, download_error_message(url, { Authorization = "Bearer " .. opts.token }, status)
	end

	-- zip.unpack creates the target dir; OVERWRITE replaces conflicts, SKIP keeps existing files.
	local unpack_ok, result, unpack_err = pcall(zip.unpack, tmp, target, {
		on_conflict = opts.overwrite and zip.ON_CONFLICT.OVERWRITE or zip.ON_CONFLICT.SKIP,
	})
	os.remove(tmp)

	if not unpack_ok then
		return false, "failed to unpack archive: " .. tostring(result)
	end
	if result == false then
		return false, "failed to unpack archive: " .. tostring(unpack_err)
	end

	-- Drop assets before path adaptation, so no reference is rewritten into a deleted dir.
	if not opts.include_assets then
		pcall(editor.delete_directory, "/" .. folder .. "/assets")
	end

	pcall(adapt_resource_paths, target, root.path)

	local convert_note
	if opts.convert_tilemap then
		local converted, isometric = convert_orthogonal_collections(target, root.path)
		if converted > 0 or isometric > 0 then
			local bits = {}
			if converted > 0 then
				bits[#bits + 1] = converted .. (converted == 1 and " map" or " maps") .. " converted to native tile maps"
			end
			if isometric > 0 then
				bits[#bits + 1] = isometric .. (isometric == 1 and " isometric map" or " isometric maps") .. " kept as .collection"
			end
			convert_note = table.concat(bits, "; ")
		end
	end

	return true, nil, convert_note
end

-- ----------------------------------------------------------------------------
-- Release / version helpers
-- ----------------------------------------------------------------------------

---Newest published release id (last non-"dev" entry, oldest→newest ordering).
---@param releases table
---@return string|nil
local function newest_release_id(releases)
	for i = #releases, 1, -1 do
		if releases[i] ~= "dev" then
			return releases[i]
		end
	end
	return nil
end

---Default release id for a card: the live "dev" build when offered, else the newest published, else "latest".
---@param project table
---@return string
local function default_release(project)
	local releases = project.releases_id or EMPTY_LIST
	for _, id in ipairs(releases) do
		if id == "dev" then
			return "dev"
		end
	end
	return newest_release_id(releases) or "latest"
end

---Human-friendly label for a release id in the version dropdown.
---@param id string
---@param newest string|nil newest published id (gets a "(latest)" marker)
---@return string
local function release_label(id, newest)
	if id == "dev" then
		return "Development build"
	elseif id == "latest" then
		return "Latest release"
	elseif newest and id == newest then
		return "Release #" .. id .. " (latest)"
	end
	return "Release #" .. id
end

---Return a copy of `map` with `key` set to `value` (immutable state update).
---@param map table
---@param key any
---@param value any
---@return table
local function with_key(map, key, value)
	local copy = {}
	for k, v in pairs(map) do
		copy[k] = v
	end
	copy[key] = value
	return copy
end

---Return a copy of `map` without `key` (immutable removal).
---@param map table
---@param key any
---@return table
local function without_key(map, key)
	local copy = {}
	for k, v in pairs(map) do
		if k ~= key then
			copy[k] = v
		end
	end
	return copy
end

---Client-side title filter for the non-marketplace tabs (the API has no `q` for those).
---@param list table
---@param query string
---@return table
local function filter_by_title(list, query)
	if not query or query == "" then
		return list
	end
	local lower = string.lower(query)
	local out = {}
	for _, project in ipairs(list) do
		local title = string.lower(project.title or project.name or "")
		if string.find(title, lower, 1, true) then
			out[#out + 1] = project
		end
	end
	return out
end

---Normalize a get_public_projects response into the dialog's marketplace state.
---@param body table|nil
---@return table
local function make_marketplace(body)
	return {
		items = (body and body.projects) or {},
		page = (body and body.page) or 1,
		total_pages = (body and body.total_pages) or 1,
	}
end

