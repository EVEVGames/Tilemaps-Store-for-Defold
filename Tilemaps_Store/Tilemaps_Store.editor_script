-- Editable destination folder (resource_field, validated via `issue`) + include-assets / overwrite choices,
-- all remembered per slug. The typed path only commits on Enter/blur, so existence checks run in on_value_changed.

local download_options_dialog = editor.ui.component(function(props)
	local folder, set_folder = editor.ui.use_state(props.folder)
	local exists, set_exists = editor.ui.use_state(props.folder_exists)
	local is_file, set_is_file = editor.ui.use_state(props.folder_is_file)
	local include_assets, set_include_assets = editor.ui.use_state(props.include_assets)
	local overwrite, set_overwrite = editor.ui.use_state(props.overwrite)
	local convert_tilemap, set_convert_tilemap = editor.ui.use_state(props.convert_tilemap)

	local issue_msg = folder_issue_message(folder, is_file)
	local issue
	if issue_msg then
		issue = { severity = editor.ui.ISSUE_SEVERITY.ERROR, message = issue_msg }
	end

	local children = {
		editor.ui.paragraph({
			text = "Folder (relative to the project root) that will receive the download:",
			color = editor.ui.COLOR.TEXT,
		}),
		editor.ui.resource_field({
			value = "/" .. folder,
			issue = issue,
			title = "Select destination folder",
			on_value_changed = function(value)
				local path = (value or ""):gsub("^/+", "")
				local now_exists, now_is_file = folder_state(path)
				-- The selector only lists files; picking one means "use its containing folder".
				if now_is_file then
					local parent = path:match("^(.*)/[^/]+$")
					if parent and parent ~= "" then
						path = parent
						now_exists, now_is_file = folder_state(path)
					end
				end
				set_folder(path)
				set_exists(now_exists)
				set_is_file(now_is_file)
			end,
		}),
		-- Static label: check_box text is single-line, so a folder path here would stretch the dialog.
		editor.ui.check_box({
			value = include_assets,
			on_value_changed = set_include_assets,
			text = "Include project assets",
			tooltip = 'When unchecked, the export\'s "assets" subfolder (source art) '
				.. "is removed right after extraction.",
		}),
	}
	-- Always shown; only usable once the chosen folder exists (a first download has nothing to overwrite).
	children[#children + 1] = editor.ui.check_box({
		value = overwrite,
		on_value_changed = set_overwrite,
		enabled = exists and not issue_msg,
		text = "Overwrite existing files",
		tooltip = "When unchecked, files already in the folder are kept and "
			.. "only new files are added.",
	})
	children[#children + 1] = editor.ui.check_box({
		value = convert_tilemap,
		on_value_changed = set_convert_tilemap,
		text = "Convert orthogonal maps to native tile maps",
		tooltip = "Tilemaps.com exports every project as a .collection, the format that supports "
			.. "isometric maps and tile animation. When checked, orthogonal maps are converted to "
			.. "Defold's native .tilemap after download for better runtime performance with large "
			.. "maps, replacing the .collection with a lightweight .go + .tilemap pair. Native tile "
			.. "maps don't support animated tiles, and only support orthogonal projection, so "
			.. "isometric maps are always kept as .collection. Download again with this unchecked "
			.. "to get the original .collection back.",
	})

	-- Existing folder => this is an update; word the title/confirm button to match the card button.
	local action = exists and "Update" or "Download"

	return editor.ui.dialog({
		title = action .. " project",
		content = editor.ui.vertical({
			padding = editor.ui.PADDING.LARGE,
			spacing = editor.ui.SPACING.MEDIUM,
			children = children,
		}),
		buttons = {
			editor.ui.dialog_button({ text = "Cancel", cancel = true }),
			editor.ui.dialog_button({
				text = action,
				default = true,
				enabled = issue_msg == nil,
				result = {
					folder = folder,
					include_assets = include_assets,
					overwrite = overwrite,
					convert_tilemap = convert_tilemap,
				},
			}),
		},
	})
end)

-- ----------------------------------------------------------------------------
-- Download action (runs from a card's Download button)
-- ----------------------------------------------------------------------------

---@param project table project record from the API
---@param ctx table { token, selection, set_status }
local function download_project(project, ctx)
	local slug = project.slug
	local release_id = ctx.selection[slug] or default_release(project)
	local title = project.title or project.name or slug

	-- Options gate, prefilled from the remembered per-slug choices (folder falls back to the project default).
	local saved_folders = editor.prefs.get(PREF_FOLDERS) or EMPTY_LIST
	local initial_folder = saved_folders[slug] or project.folder or slug
	local initial_exists, initial_is_file = folder_state(initial_folder)
	local opts = editor.ui.show_dialog(download_options_dialog({
		folder = initial_folder,
		folder_exists = initial_exists,
		folder_is_file = initial_is_file,
		include_assets = not slug_flag(PREF_NO_ASSETS, slug),
		overwrite = slug_flag(PREF_OVERWRITE, slug),
		convert_tilemap = not slug_flag(PREF_KEEP_COLLECTION, slug),
	}))
	if not opts then
		ctx.set_status("Download cancelled.")
		return
	end

	-- Re-validate the chosen folder outside the dialog (belt and braces).
	local folder = opts.folder
	local folder_exists, folder_is_file = folder_state(folder)
	local bad = folder_issue_message(folder, folder_is_file)
	if bad then
		ctx.set_status("Download cancelled: " .. bad)
		return
	end

	-- Remember the choices for next time (overwrite only when the folder existed and the box was shown).
	editor.prefs.set(PREF_FOLDERS, with_key(saved_folders, slug, folder))
	set_slug_flag(PREF_NO_ASSETS, slug, not opts.include_assets)
	set_slug_flag(PREF_KEEP_COLLECTION, slug, not opts.convert_tilemap)
	if folder_exists then
		set_slug_flag(PREF_OVERWRITE, slug, opts.overwrite)
	end

	local url = BASE_URL .. "/project/" .. url_encode(slug) .. "/download/" .. DOWNLOAD_FMT
		.. "?release_id=" .. url_encode(release_id)

	-- Existing folder => "update"; fresh folder => "download". Match the card button wording.
	local verb_ing = folder_exists and "Updating" or "Downloading"
	local verb_done = folder_exists and "Updated" or "Downloaded"
	local verb_fail = folder_exists and "Update" or "Download"

	ctx.set_status(verb_ing .. " '" .. title .. "'…")
	print("[Tilemaps Store] " .. verb_ing .. " '" .. title .. "' (release " .. release_id .. ")…")
	local ok, err, convert_note = download_and_extract(url, folder, {
		token = ctx.token,
		overwrite = opts.overwrite or not folder_exists,  -- nothing to keep in a fresh folder
		include_assets = opts.include_assets,
		convert_tilemap = opts.convert_tilemap,
	})
	if ok then
		-- Status BEFORE editor.save/prefs.set: those consume the render cycle, so a later set_status
		-- wouldn't repaint until the next UI event (bar stuck on "Downloading…").
		local done_msg = verb_done .. " '" .. title .. "' to /" .. folder
		if convert_note then
			done_msg = done_msg .. " (" .. convert_note .. ")"
		end
		ctx.set_status(done_msg)
		print("[Tilemaps Store] " .. done_msg)
		editor.prefs.set(PREF_TITLES, with_key(editor.prefs.get(PREF_TITLES) or EMPTY_LIST, slug, title))
		pcall(editor.save)
	else
		ctx.set_status(verb_fail .. " failed: " .. tostring(err))
		print("[Tilemaps Store] " .. verb_fail .. " failed: " .. tostring(err))
	end
end

-- ----------------------------------------------------------------------------
-- Card (plain builder — no hooks, so a function is enough)
-- ----------------------------------------------------------------------------

---Pluralized tally fragment; nil when the count is unknown, or 0 with hide_zero (used for assets).
---@param count any numeric *_count field from the API
---@param list any array-of-records alternative from the API
---@param singular string
---@param hide_zero boolean|nil omit the fragment when the count is 0
---@return string|nil
local function tally_label(count, list, singular, hide_zero)
	local n = count
	if type(n) ~= "number" then
		n = type(list) == "table" and #list or nil
	end
	if type(n) ~= "number" then
		return nil
	end
	if hide_zero and n == 0 then
		return nil
	end
	return n .. " " .. singular .. (n == 1 and "" or "s")
end

---Filled/empty star string for a rating, or nil when there are no reviews.
local function rating_stars(avg, count)
	if not count or count <= 0 or not avg or avg <= 0 then
		return nil
	end
	local filled = math.floor(avg + 0.5)
	if filled < 0 then filled = 0 elseif filled > 5 then filled = 5 end
	return string.rep("★", filled) .. string.rep("☆", 5 - filled)
end

---Project page URL — the API's `url` when present, else built from the slug.
local function project_page_url(project)
	if project.url and project.url ~= "" then
		return project.url
	end
	return BASE_URL .. "/project/" .. (project.slug or "")
end

---@param project table
---@param ctx table { token, selection, set_selection, set_status, saved_folders }
---@return userdata component
local function build_card(project, ctx)
	local slug = project.slug
	local title = project.title or project.name or slug
	local releases = project.releases_id or EMPTY_LIST
	local newest = newest_release_id(releases)
	local options = (#releases > 0) and releases or { "latest" }
	local selected = ctx.selection[slug] or default_release(project)

	-- Button verb (Update vs Download) from whether the folder the modal would prefill already exists.
	local dest_folder = (ctx.saved_folders or EMPTY_LIST)[slug] or project.folder or slug
	local already_here = folder_state(dest_folder)

	local left = {}
	local thumb = first_thumb(project.thumbnails)
	if thumb and editor.ui.image then
		left[#left + 1] = editor.ui.image({ image = thumb, width = 120 })
	end

	local title_row = {}
	local stars = rating_stars(project.avg_rating, project.review_count)
	if stars then
		title_row[#title_row + 1] = editor.ui.label({
			text = stars,
			color = editor.ui.COLOR.HINT,
		})
	end
	title_row[#title_row + 1] = editor.ui.heading({
		text = title,
		style = editor.ui.HEADING_STYLE.H5,
	})
	if project.visibility and project.visibility ~= "" then
		title_row[#title_row + 1] = editor.ui.label({
			text = "[" .. project.visibility .. "]",
			color = (project.visibility == "private")
				and editor.ui.COLOR.WARNING or editor.ui.COLOR.HINT,
		})
	end
	if project.role and project.role ~= "" then
		title_row[#title_row + 1] = editor.ui.label({
			text = "(" .. project.role .. ")",
			color = editor.ui.COLOR.HINT,
		})
	end
	title_row[#title_row + 1] = editor.ui.horizontal({ grow = true })
	title_row[#title_row + 1] = editor.ui.button({
		icon = editor.ui.ICON.OPEN_RESOURCE,
		on_pressed = function() editor.browse(project_page_url(project)) end,
	})

	local info = {
		editor.ui.horizontal({ spacing = editor.ui.SPACING.SMALL, children = title_row }),
	}
	if project.owner and project.owner ~= "" then
		info[#info + 1] = editor.ui.label({
			text = "by " .. project.owner,
			color = editor.ui.COLOR.OVERRIDE,
		})
	end
	if project.description and project.description ~= "" then
		info[#info + 1] = editor.ui.paragraph({
			text = project.description,
			color = editor.ui.COLOR.TEXT,
		})
	end
	-- Content tallies (nil ones skipped). Assets hide a 0; tilemaps/tilesets keep it (meaningful when a project is one-or-the-other).
	local meta = {}
	meta[#meta + 1] = tally_label(project.tilemap_count, project.tilemaps, "tilemap")
	meta[#meta + 1] = tally_label(project.tileset_count, project.tilesets, "tileset")
	meta[#meta + 1] = tally_label(project.asset_count, project.assets, "asset", true)
	if #meta > 0 then
		info[#info + 1] = editor.ui.label({
			text = table.concat(meta, " · "),
			color = editor.ui.COLOR.HINT,
		})
	end

	-- downloadable=false (paid & not owned) => send to the project page instead of offering a download.
	if project.downloadable == false then
		info[#info + 1] = editor.ui.button({
			text = "Get this project",
			on_pressed = function()
				if project.url and project.url ~= "" then
					editor.browse(project.url)
				end
			end,
		})
	else
		info[#info + 1] = editor.ui.horizontal({
			spacing = editor.ui.SPACING.SMALL,
			children = {
				editor.ui.select_box({
					value = selected,
					options = options,
					to_string = function(id) return release_label(id, newest) end,
					on_value_changed = function(id)
						ctx.set_selection(with_key(ctx.selection, slug, id))
					end,
					grow = true,
				}),
				editor.ui.button({
					text = already_here and "Update" or "Download",
					on_pressed = function() download_project(project, ctx) end,
				}),
			},
		})
	end

	local row = {}
	if #left > 0 then
		row[#row + 1] = editor.ui.vertical({ children = left })
	end
	row[#row + 1] = editor.ui.vertical({
		grow = true,
		spacing = editor.ui.SPACING.SMALL,
		children = info,
	})

	return editor.ui.vertical({
		spacing = editor.ui.SPACING.SMALL,
		children = {
			editor.ui.horizontal({ spacing = editor.ui.SPACING.MEDIUM, children = row }),
			editor.ui.separator({}),
		},
	})
end

-- ----------------------------------------------------------------------------
-- Downloaded tab (local registry, enriched from the API for update controls)
-- ----------------------------------------------------------------------------

---Base list for the Downloaded tab from prefs, keeping only slugs whose folder still exists on disk.
---@return table records array of { slug, title, folder } sorted by title
local function load_downloaded_records()
	local folders = editor.prefs.get(PREF_FOLDERS) or EMPTY_LIST
	local titles = editor.prefs.get(PREF_TITLES) or EMPTY_LIST
	local out = {}
	for slug, folder in pairs(folders) do
		local exists, is_file = folder_state(folder)
		if exists and not is_file then
			out[#out + 1] = { slug = slug, title = titles[slug] or slug, folder = folder }
		end
	end
	table.sort(out, function(a, b) return string.lower(a.title) < string.lower(b.title) end)
	return out
end

---Move every project in `list` whose slug is still in `remaining` into `by_slug` and mark it resolved.
---@param by_slug table slug -> full project record (accumulator)
---@param remaining table slug -> true (still unresolved; entries removed here)
---@param list table|nil array of project records from an endpoint
local function resolve_from_list(by_slug, remaining, list)
	if type(list) ~= "table" then return end
	for _, project in ipairs(list) do
		if project.slug and remaining[project.slug] then
			by_slug[project.slug] = project
			remaining[project.slug] = nil
		end
	end
end

---Attach each downloaded record's full API record (record.project) for update controls.
---Order stops when all resolve: my_projects → collaborations → public(slug=csv) → purchases.
---Owner/collaborator endpoints go first so an owned public project keeps its "dev" build (public strips it).
---@param records table array of { slug, title, folder }
---@param token string
local function enrich_downloaded(records, token)
	if #records == 0 then return end

	local remaining, slugs = {}, {}
	for _, r in ipairs(records) do
		remaining[r.slug] = true
		slugs[#slugs + 1] = r.slug
	end
	local function any_remaining()
		return next(remaining) ~= nil
	end

	local by_slug = {}
	local b = api_get("get_my_projects", token)
	resolve_from_list(by_slug, remaining, b and b.projects)

	if any_remaining() then
		b = api_get("get_collaborations", token)
		resolve_from_list(by_slug, remaining, b and b.collaborations)
	end

	if any_remaining() then
		b = api_get("get_public_projects", token, {
			slug = table.concat(slugs, ","),
			per_page = 50,
			page = 1,
		})
		resolve_from_list(by_slug, remaining, b and b.projects)
	end

	if any_remaining() then
		b = api_get("get_purchases", token)
		resolve_from_list(by_slug, remaining, b and b.purchases)
	end

	for _, r in ipairs(records) do
		r.project = by_slug[r.slug]
	end
end

