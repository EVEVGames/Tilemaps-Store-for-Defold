				enabled = token ~= "",
				result = token,
			}),
		},
	})
end)

---Verify a token cheaply against an authenticated endpoint.
---@param token string
---@return string|nil err nil when valid, "unauthorized" or a message otherwise
local function validate_token(token)
	local _, err = api_get("get_public_projects", token, { page = 1, per_page = 1 })
	return err
end

---Prompt for a token, validating each attempt, until valid or cancelled (nil = cancelled).
---@param message string|nil initial message shown above the field
---@return string|nil token
local function prompt_for_token(message)
	local prefill = editor.prefs.get(PREF_TOKEN) or ""
	local severity = editor.ui.ISSUE_SEVERITY.ERROR
	while true do
		local entered = editor.ui.show_dialog(token_dialog({
			message = message,
			severity = severity,
			prefill = prefill,
		}))
		if not entered then
			return nil
		end
		prefill = entered
		local err = validate_token(entered)
		if not err then
			editor.prefs.set(PREF_TOKEN, entered)
			return entered
		elseif err == "unauthorized" then
			message = "Invalid token. Check your account settings and try again."
			severity = editor.ui.ISSUE_SEVERITY.ERROR
		else
			message = "Could not verify token (" .. err .. "). Try again."
			severity = editor.ui.ISSUE_SEVERITY.WARNING
		end
	end
end

