---Card for a downloaded project: title (+ thumbnail), download path, update control (when resolved), and Delete.
---@param record table { slug, title, folder, project? }
---@param ctx table { token, selection, set_selection, set_status, remove_downloaded }
---@return userdata component
local function build_downloaded_card(record, ctx)
	local project = record.project

	local left = {}
	local thumb = project and first_thumb(project.thumbnails)
	if thumb and editor.ui.image then
		left[#left + 1] = editor.ui.image({ image = thumb, width = 96 })
	end

	local page_url = (project and project.url and project.url ~= "" and project.url)
		or (BASE_URL .. "/project/" .. record.slug)
	local title_row = {
		editor.ui.heading({ text = record.title, style = editor.ui.HEADING_STYLE.H5 }),
		editor.ui.horizontal({ grow = true }),
		editor.ui.button({
			icon = editor.ui.ICON.OPEN_RESOURCE,
			on_pressed = function() editor.browse(page_url) end,
		}),
	}

	local info = {
		editor.ui.horizontal({ spacing = editor.ui.SPACING.SMALL, children = title_row }),
		editor.ui.label({ text = "Downloaded to /" .. record.folder, color = editor.ui.COLOR.HINT }),
	}

	-- Update control only when the project resolved from the API and is downloadable; re-downloads in place.
	if project and project.downloadable ~= false then
		local releases = project.releases_id or EMPTY_LIST
		local newest = newest_release_id(releases)
		local options = (#releases > 0) and releases or { "latest" }
		local selected = ctx.selection[record.slug] or default_release(project)
		info[#info + 1] = editor.ui.horizontal({
			spacing = editor.ui.SPACING.SMALL,
			children = {
				editor.ui.select_box({
					value = selected,
					options = options,
					to_string = function(id) return release_label(id, newest) end,
					on_value_changed = function(id)
						ctx.set_selection(with_key(ctx.selection, record.slug, id))
					end,
					grow = true,
				}),
				editor.ui.button({
					text = "Update",
					on_pressed = function() download_project(project, ctx) end,
				}),
			},
		})
	end

	info[#info + 1] = editor.ui.button({
		text = "Delete",
		on_pressed = function()
			local decision = editor.ui.show_dialog(delete_dialog({
				folder = record.folder,
				title = record.title,
			}))
			if decision ~= "delete" then
				return
			end
			local slug, folder, ttl = record.slug, record.folder, record.title
			-- Update the UI BEFORE the delete: editor.delete_directory consumes the render cycle, so a
			-- set_status / list update after it wouldn't repaint until the next event. Delete + prefs run last.
			ctx.remove_downloaded(slug)
			ctx.set_status("Deleted '" .. ttl .. "' (/" .. folder .. ").")
			local ok, err = pcall(editor.delete_directory, "/" .. folder)
			if ok then
				editor.prefs.set(PREF_FOLDERS, without_key(editor.prefs.get(PREF_FOLDERS) or EMPTY_LIST, slug))
				editor.prefs.set(PREF_TITLES, without_key(editor.prefs.get(PREF_TITLES) or EMPTY_LIST, slug))
				print("[Tilemaps Store] Deleted '" .. ttl .. "' (/" .. folder .. ")")
			else
				-- Rare (e.g. a locked file): optimistic UI is ahead of disk, but prefs/folder are intact,
				-- so the entry reappears on the next reload. Log it since the bar can't repaint a correction.
				print("[Tilemaps Store] Delete failed for /" .. folder .. ": " .. tostring(err))
			end
		end,
	})

	local row = {}
	if #left > 0 then
		row[#row + 1] = editor.ui.vertical({ children = left })
	end
	row[#row + 1] = editor.ui.vertical({
		grow = true,
		spacing = editor.ui.SPACING.SMALL,
		children = info,
	})

	return editor.ui.vertical({
		spacing = editor.ui.SPACING.SMALL,
		children = {
			editor.ui.horizontal({ spacing = editor.ui.SPACING.MEDIUM, children = row }),
			editor.ui.separator({}),
		},
	})
end

-- ----------------------------------------------------------------------------
-- Main store dialog (reactive component)
-- ----------------------------------------------------------------------------

local store_dialog = editor.ui.component(function(props)
	local token = props.token
	local tab, set_tab = editor.ui.use_state("marketplace")
	local query, set_query = editor.ui.use_state("")
	local marketplace, set_marketplace = editor.ui.use_state(props.initial_marketplace)
	local my, set_my = editor.ui.use_state(NOT_LOADED)                     -- lazy
	local collaborations, set_collaborations = editor.ui.use_state(NOT_LOADED)
	local purchases, set_purchases = editor.ui.use_state(NOT_LOADED)
	local downloaded, set_downloaded = editor.ui.use_state(NOT_LOADED)       -- local registry
	local selection, set_selection = editor.ui.use_state(new_map)
	local status, set_status = editor.ui.use_state(props.initial_status or "")

	local source = my
	if tab == "collaborations" then
		source = collaborations
	elseif tab == "purchases" then
		source = purchases
	elseif tab == "downloaded" then
		source = downloaded
	end
	local source_list = (source == NOT_LOADED) and EMPTY_LIST or source
	local filtered = editor.ui.use_memo(filter_by_title, source_list, query)

	-- Loaders — only ever called from callbacks, never in render.
	local function reload_marketplace(page, search)
		local body, err = api_get("get_public_projects", token, {
			page = page,
			per_page = PER_PAGE,
			q = search,
		})
		if err then
			set_status("Error: " .. err)
			return
		end
		set_marketplace(make_marketplace(body))
		set_status("")
	end

	local function load_list(method, key, setter)
		local body, err = api_get(method, token)
		if err then
			set_status("Error: " .. err)
			return
		end
		setter((body and body[key]) or {})
		set_status("")
	end

	-- Downloaded: read prefs + re-check folders, then enrich via the API. Reloads on every activation.
	local function reload_downloaded()
		local records = load_downloaded_records()
		enrich_downloaded(records, token)
		set_downloaded(records)
	end

	-- Drop one entry locally (no API); delete uses this before editor.delete_directory so the UI repaints.
	local function remove_downloaded(slug)
		if downloaded == NOT_LOADED then
			return
		end
		local out = {}
		for _, r in ipairs(downloaded) do
			if r.slug ~= slug then
				out[#out + 1] = r
			end
		end
		set_downloaded(out)
	end

	local list = (tab == "marketplace") and marketplace.items or filtered

	-- Read once so build_card can label its button Update vs Download.
	local saved_folders = editor.prefs.get(PREF_FOLDERS) or EMPTY_LIST

	local cards = {}
	for _, project in ipairs(list) do
		if tab == "downloaded" then
			cards[#cards + 1] = build_downloaded_card(project, {
				token = token,
				selection = selection,
				set_selection = set_selection,
				set_status = set_status,
				remove_downloaded = remove_downloaded,
			})
		else
			cards[#cards + 1] = build_card(project, {
				token = token,
				selection = selection,
				set_selection = set_selection,
				set_status = set_status,
				saved_folders = saved_folders,
			})
		end
	end
	if #cards == 0 then
		local empty_text = "No projects found."
		if query == "" then
			if tab == "my" and my ~= NOT_LOADED then
				empty_text = "You don't have any projects yet."
			elseif tab == "collaborations" and collaborations ~= NOT_LOADED then
				empty_text = "You don't collaborate on any project yet."
			elseif tab == "purchases" and purchases ~= NOT_LOADED then
				empty_text = "You haven't purchased any projects yet."
			elseif tab == "downloaded" and downloaded ~= NOT_LOADED then
				empty_text = "No downloaded projects found on disk yet."
			end
		end
		cards[1] = editor.ui.label({ text = empty_text, color = editor.ui.COLOR.HINT })
	end

	-- One tab button; loads its data lazily on first activation.
	local function tab_button(label, id)
		return editor.ui.button({
			text = label,
			enabled = tab ~= id,
			on_pressed = function()
				set_tab(id)
				set_query("")
				if id == "marketplace" then
					reload_marketplace(1, "")
				elseif id == "my" and my == NOT_LOADED then
					load_list("get_my_projects", "projects", set_my)
				elseif id == "collaborations" and collaborations == NOT_LOADED then
					load_list("get_collaborations", "collaborations", set_collaborations)
				elseif id == "purchases" and purchases == NOT_LOADED then
					load_list("get_purchases", "purchases", set_purchases)
				elseif id == "downloaded" then
					reload_downloaded()
				end
			end,
		})
	end

	local header_children = {
		editor.ui.horizontal({
			spacing = editor.ui.SPACING.SMALL,
			children = {
				tab_button("Explore", "marketplace"),
				tab_button("My Projects", "my"),
				tab_button("My Collaborations", "collaborations"),
				tab_button("My Purchases", "purchases"),
				tab_button("Downloaded", "downloaded"),
			},
		}),
		editor.ui.string_field({
			value = query,
			on_value_changed = function(text)
				set_query(text)
				if tab == "marketplace" then
					reload_marketplace(1, text)
				end
			end,
		}),
	}

	local body_children = {
		editor.ui.vertical({ spacing = editor.ui.SPACING.SMALL, children = header_children }),
		editor.ui.separator({}),
	}

	if tab == "marketplace" and marketplace.total_pages > 1 then
		local page = marketplace.page
		local total = marketplace.total_pages
		body_children[#body_children + 1] = editor.ui.horizontal({
			spacing = editor.ui.SPACING.SMALL,
			alignment = editor.ui.ALIGNMENT.CENTER,
			children = {
				editor.ui.button({
					text = "◀ Prev",
					enabled = page > 1,
					on_pressed = function() reload_marketplace(page - 1, query) end,
				}),
				editor.ui.label({ text = "Page " .. page .. " / " .. total }),
				editor.ui.button({
					text = "Next ▶",
					enabled = page < total,
					on_pressed = function() reload_marketplace(page + 1, query) end,
				}),
			},
		})
	end

	body_children[#body_children + 1] = editor.ui.scroll({
		grow = true,
		content = editor.ui.vertical({ spacing = editor.ui.SPACING.LARGE, children = cards }),
	})

	if status ~= "" then
		body_children[#body_children + 1] = editor.ui.label({
			text = status,
			color = editor.ui.COLOR.HINT,
		})
	end

	return editor.ui.dialog({
		title = "Tilemaps Store",
		header = editor.ui.horizontal({
			spacing = editor.ui.SPACING.MEDIUM,
			alignment = editor.ui.ALIGNMENT.CENTER,
			children = {
				editor.ui.image({ image = LOGO_URL, height = 28 }),
				editor.ui.horizontal({ grow = true }),
				editor.ui.label({
					text = props.username and ("@" .. props.username) or "",
					color = editor.ui.COLOR.HINT,
				}),
				editor.ui.button({
					text = "Profile",
					enabled = props.username ~= nil,
					on_pressed = function()
						if props.username then
							editor.browse(BASE_URL .. "/user/" .. props.username)
						end
					end,
				}),
			},
		}),
		content = editor.ui.vertical({
			padding = editor.ui.PADDING.MEDIUM,
			spacing = editor.ui.SPACING.MEDIUM,
			children = body_children,
		}),
		buttons = {
			editor.ui.dialog_button({ text = "Close", cancel = true }),
		},
	})
end)

-- ----------------------------------------------------------------------------
-- Entry point
-- ----------------------------------------------------------------------------

local function open_store()
	local token = editor.prefs.get(PREF_TOKEN) or ""

	-- Validate the saved token by fetching the first marketplace page; prompt when missing or rejected.
	local body, err
	if token ~= "" then
		body, err = api_get("get_public_projects", token, { page = 1, per_page = PER_PAGE })
	end
	if token == "" or err == "unauthorized" then
		token = prompt_for_token(token == "" and nil
			or "Your saved token is invalid. Enter a new one.")
		if not token then
			return
		end
		body, err = api_get("get_public_projects", token, { page = 1, per_page = PER_PAGE })
	end

	local me = api_get("get_me", token)
	local username = type(me) == "table" and me.username or nil

	editor.ui.show_dialog(store_dialog({
		token = token,
		username = username,
		initial_marketplace = make_marketplace(body),
		initial_status = err and ("Error: " .. err) or "",
	}))
end

