		end,
	})
	children[#children + 1] = editor.ui.button({
		text = "Open account settings",
		on_pressed = function()
			editor.browse(BASE_URL .. "/settings/account")
		end,
	})

	return editor.ui.dialog({
		title = "Tilemaps.com — API Token",
		header = editor.ui.horizontal({
