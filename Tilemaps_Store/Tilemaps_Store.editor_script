			alignment = editor.ui.ALIGNMENT.CENTER,
			children = {
				editor.ui.image({ image = LOGO_URL, height = 24 }),
				editor.ui.heading({ text = "API Token", style = editor.ui.HEADING_STYLE.DIALOG }),
			},
		}),
		content = editor.ui.vertical({
