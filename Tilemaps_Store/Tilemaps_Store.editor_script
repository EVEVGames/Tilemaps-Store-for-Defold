-- Files we never rewrite/scan as text during path adaptation.
local BINARY_EXT = {
	png = true, jpg = true, jpeg = true, gif = true, bmp = true, tga = true,
	psd = true, wav = true, ogg = true, opus = true, mp3 = true, ttf = true,
